{
  "version": 2,
  "builds": [
    {
      "src": "vite.config.ts",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}

